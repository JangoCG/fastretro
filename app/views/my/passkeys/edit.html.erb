<% content_for :title, t("my.passkeys.edit.title") %>

<div class="max-w-md mx-auto px-4 py-8 font-sans">
  <div class="bg-[#F8F5EC] border-[3px] border-zinc-900 shadow-[8px_8px_0px_0px_rgba(20,20,23,0.8)] relative">

    <%# Header %>
    <div class="p-4 border-b-[3px] border-zinc-900 flex items-center justify-between">
      <%= link_to my_passkeys_path, class: "text-xs font-bold text-zinc-500 uppercase tracking-widest hover:text-zinc-900 transition-colors" do %>
        &larr; <%= t("my.passkeys.edit.back") %>
      <% end %>
      <h1 class="text-sm font-black text-zinc-900 uppercase tracking-widest"><%= t("my.passkeys.edit.title") %></h1>
    </div>

    <%# Body %>
    <div class="p-6 bg-white relative">
      <div class="absolute inset-0 pointer-events-none bg-[linear-gradient(to_right,#8080800a_1px,transparent_1px),linear-gradient(to_bottom,#8080800a_1px,transparent_1px)] bg-[size:10px_10px]"></div>

      <div class="relative z-10 flex flex-col gap-6">
        <% if params[:created] %>
          <p class="text-xs font-bold text-green-600 uppercase tracking-wide"><%= t("my.passkeys.edit.registered") %></p>
        <% end %>

        <%= form_with model: @passkey, scope: :passkey, url: my_passkey_path(@passkey), class: "flex flex-col gap-4" do |form| %>
          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold text-zinc-500 uppercase tracking-widest font-mono"><%= t("my.passkeys.edit.name_label") %></label>
            <%= form.text_field :name,
                autofocus: true,
                class: "w-full px-4 py-3 bg-[#F8F5EC] border-[2px] border-zinc-900 text-zinc-900 font-bold placeholder-zinc-400 focus:outline-none focus:bg-white focus:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all rounded-none",
                placeholder: t("my.passkeys.edit.name_placeholder"),
                autocomplete: "off",
                data: { "1p-ignore": "" } %>
          </div>

          <%= form.submit t("my.passkeys.edit.save"), class: "group relative flex items-center justify-center gap-3 w-full py-3 bg-zinc-900 text-[#F8F5EC] border-[2px] border-zinc-900 font-black uppercase tracking-widest text-xs hover:-translate-y-1 hover:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] active:translate-y-0 active:shadow-none transition-all cursor-pointer" %>
        <% end %>

        <div class="flex justify-center">
          <%= button_to my_passkey_path(@passkey), method: :delete,
                class: "text-xs font-bold text-red-500 uppercase tracking-widest hover:text-red-700 transition-colors cursor-pointer",
                data: { turbo_confirm: t("my.passkeys.edit.confirm_delete") } do %>
            <%= t("my.passkeys.edit.remove") %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
